{
  "name": "anpm-io",
  "version": "1.0.0",
  "description": "anpm — the agent package manager",
  "main": "dist/index.js",
  "bin": {
    "anpm": "./dist/index.js",
    "relay": "./dist/relay-compat.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && cp src/prompts/*.md dist/prompts/",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "postinstall": "node dist/postinstall.js || true",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agent",
    "skills",
    "marketplace",
    "cli",
    "claude",
    "llm",
    "ai-agent",
    "relayax",
    "anpm",
    "agent-npm",
    "package-manager"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Musibe/relayax-cli-public"
  },
  "homepage": "https://anpm.io",
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^13.1.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "typescript": "^5"
  }
}
